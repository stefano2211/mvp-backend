# =========================================
# Industrial Digital Optimus — .env.example
# =========================================
# Copy this file to .env and fill in your values.

# --- Local Inference (vLLM) ---
# Base URL of the vLLM OpenAI-compatible endpoint. Inside Docker network it is
# http://vllm_engine:8000/v1; from the host it is http://localhost:8002/v1.
LOCAL_VLLM_URL=http://vllm_engine:8000/v1
LOCAL_VLLM_API_KEY=not-needed-for-local

# Model used for System-2 (deliberate reasoning, orchestrator)
ORCHESTRATOR_MODEL=Qwen/Qwen3.5-27B-FP8
ORCHESTRATOR_TEMPERATURE=0.2

# Model used for System-1 (fast intuition, sensor-classifier + screen-analyzer).
# If unset, falls back to ORCHESTRATOR_MODEL. On multi-GPU setups, point this
# to a smaller model served by a separate vLLM instance for true Fast Intuition.
# SYSTEM1_MODEL=Qwen/Qwen2.5-7B-Instruct
SYSTEM1_TEMPERATURE=0.1

# Hugging Face token (required for some gated Qwen weights)
HF_TOKEN=

# --- OmniParser ---
OMNIPARSER_URL=http://omniparser_api:8003/parse
OMNIPARSER_BOX_THRESHOLD=0.05

# --- Optional cloud fallback (only if you want to swap System-2/1 for hosted models) ---
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# Optional: LangSmith tracing (highly recommended for debugging)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=industrial-optimus

# --- Service URLs (used inside Docker network) ---
AGENTS_SERVICE_URL=http://optimus_agents:8001
API_SERVICE_URL=http://optimus_api:8000

# --- Windows Client Config (used OUTSIDE Docker, on your Windows host) ---
OPTIMUS_API_URL=http://localhost:8000
SCREENSHOT_INTERVAL_SECONDS=2

# --- Ports ---
API_PORT=8000
UI_PORT=7860
AGENTS_PORT=8001
